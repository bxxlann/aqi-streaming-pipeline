# Get free API key at https://explore.openaq.org/
OPENAQ_API_KEY=your_openaq_api_key_here

# Optional: Slack incoming webhook URL for AQI alerts
# Create at https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# AQI threshold for Slack alerts (default: 150 = Unhealthy)
AQI_ALERT_THRESHOLD=150

# How often to poll OpenAQ API in seconds (default: 60)
POLL_INTERVAL_SECONDS=60
