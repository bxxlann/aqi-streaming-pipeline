{
  "title": "Almaty AQI Monitoring",
  "uid": "almaty-aqi-v1",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Current AQI by Station",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",    "value": null },
              { "color": "yellow",   "value": 51 },
              { "color": "orange",   "value": 101 },
              { "color": "red",      "value": 151 },
              { "color": "purple",   "value": 201 },
              { "color": "dark-red", "value": 301 }
            ]
          },
          "unit": "none",
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource" },
          "queryType": "sql",
          "rawSql": "SELECT location_name, argMax(aqi, measured_at) AS aqi FROM aqi.readings WHERE parameter = 'pm25' AND measured_at >= now() - INTERVAL 2 HOUR GROUP BY location_name",
          "format": 0
        }
      ]
    },
    {
      "id": 2,
      "title": "PM2.5 AQI — Last 6 Hours",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 51 },
              { "color": "orange", "value": 101 },
              { "color": "red",    "value": 151 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource" },
          "queryType": "sql",
          "rawSql": "SELECT measured_at AS time, location_name, aqi FROM aqi.readings WHERE parameter = 'pm25' AND measured_at >= now() - INTERVAL 6 HOUR ORDER BY measured_at",
          "format": 1
        }
      ]
    },
    {
      "id": 3,
      "title": "AQI Category Distribution",
      "type": "piechart",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource" },
          "queryType": "sql",
          "rawSql": "SELECT countIf(aqi_category = 'Good') AS Good, countIf(aqi_category = 'Moderate') AS Moderate, countIf(aqi_category = 'Unhealthy for Sensitive Groups') AS \"Unhealthy (Sensitive)\", countIf(aqi_category = 'Unhealthy') AS Unhealthy, countIf(aqi_category = 'Very Unhealthy') AS \"Very Unhealthy\", countIf(aqi_category = 'Hazardous') AS Hazardous FROM aqi.readings WHERE parameter = 'pm25' AND measured_at >= now() - INTERVAL 6 HOUR",
          "format": 0
        }
      ]
    },
    {
      "id": 4,
      "title": "Hourly Average AQI",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 51 },
              { "color": "orange", "value": 101 },
              { "color": "red",    "value": 151 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource" },
          "queryType": "sql",
          "rawSql": "SELECT toStartOfHour(measured_at) AS time, location_name, round(avg(aqi)) AS avg_aqi FROM aqi.readings WHERE parameter = 'pm25' AND measured_at >= now() - INTERVAL 24 HOUR GROUP BY time, location_name ORDER BY time",
          "format": 1
        }
      ]
    }
  ]
}
